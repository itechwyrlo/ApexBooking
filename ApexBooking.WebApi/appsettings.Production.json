{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "Systemd"
    }
  },
  "AllowedHosts": "apexbooking.runasp.net",
  "Jwt": {
    "Issuer": "http://apexbooking.runasp.net",
    "Audience": "http://apexbooking.runasp.net",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "ApplicationUrls": {
    "BaseUrl": "http://apexbooking.runasp.net",
    "StaffInviteAcceptPath": "/staff/accept-invite"
  },
  "AppSettings": {
    "FrontendBaseUrl": "http://apexbooking.runasp.net"
  },
  "GoogleCalendar": {
    "RedirectUri": "http://apexbooking.runasp.net/api/v1/staff/calendar/callback"
  },
  "MicrosoftGraph": {
    "RedirectUri": "http://apexbooking.runasp.net/api/outlook/callback",
    "Scopes": [ "https://outlook.office.com/SMTP.Send", "offline_access" ]
  },
  "EmailSettings": {
    "SenderName": "apexbookings"
  },
  "Cors": {
    "AllowedOrigins": "http://apexbooking.runasp.net",
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "PATCH" ],
    "AllowedHeaders": [ "Authorization", "Content-Type" ],
    "AllowCredentials": true
  },
  "Security": {
    "RequireHttps": false,
    "EnableHsts": false,
    "CookieDomain": "apexbooking.runasp.net"
  }
}
